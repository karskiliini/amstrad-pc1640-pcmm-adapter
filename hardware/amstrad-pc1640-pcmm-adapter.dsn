(pcb "hardware/amstrad-pc1640-pcmm-adapter.dsn"
  (parser
    (string_quote ")
    (space_in_quoted_tokens on)
    (host_cad "KiCad's Pcbnew")
    (host_version "9.0.7")
  )
  (resolution um 10)
  (unit um)
  (structure
    (layer F.Cu
      (type signal)
      (property
        (index 0)
      )
    )
    (layer B.Cu
      (type signal)
      (property
        (index 1)
      )
    )
    (boundary
      (path pcb 0  180000 -112000  100000 -112000  100000 -80000  180000 -80000
            180000 -112000)
    )
    (plane GND (polygon B.Cu 0  100000 -80000  180000 -80000  180000 -112000  100000 -112000
            100000 -80000))
    (via "Via[0-1]_600:300_um")
    (rule
      (width 400)
      (clearance 200)
      (clearance 50 (type smd_smd))
    )
  )
  (placement
    (component "Connector_Dsub:DSUB-9_Male_Horizontal_P2.77x2.84mm"
      (place J1 108000.000000 -100000.000000 front 0.000000 (PN DB9_Male))
    )
    (component "Package_DIP:DIP-14_W7.62mm"
      (place U1 132000.000000 -88000.000000 front 0.000000 (PN 74HC04))
      (place U2 145000.000000 -88000.000000 front 0.000000 (PN 74HC86))
    )
    (component Capacitor_THT:C_Disc_D5.0mm_W2.5mm_P2.50mm
      (place C1 133000.000000 -82000.000000 front 0.000000 (PN 100nF))
      (place C2 146000.000000 -82000.000000 front 0.000000 (PN 100nF))
    )
    (component Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P7.62mm_Horizontal
      (place R1 150000.000000 -108000.000000 front 0.000000 (PN 10k))
    )
    (component "amstrad-adapter:DIN-8_Video"
      (place J2 170000.000000 -100000.000000 front 0.000000 (PN "DIN-8"))
    )
    (component Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical
      (place J3 140000.000000 -108000.000000 front 0.000000 (PN +5V/GND))
    )
  )
  (library
    (image "Connector_Dsub:DSUB-9_Male_Horizontal_P2.77x2.84mm"
      (pin Rect[A]Pad_1600.000000x1600.000000_um 1 0 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 2 2770 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 3 5540 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 4 8310 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 5 11080 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 6 1385 -2840)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 7 4155 -2840)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 8 6925 -2840)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 9 9695 -2840)
      (pin Oval[A]Pad_3000.000000x3000.000000_um MH1 -5080 -1420)
      (pin Oval[A]Pad_3000.000000x3000.000000_um MH2 16160 -1420)
    )
    (image "Package_DIP:DIP-14_W7.62mm"
      (pin Rect[A]Pad_1600.000000x1600.000000_um 1 0 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 2 0 -2540)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 3 0 -5080)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 4 0 -7620)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 5 0 -10160)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 6 0 -12700)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 7 0 -15240)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 14 7620 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 13 7620 -2540)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 12 7620 -5080)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 11 7620 -7620)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 10 7620 -10160)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 9 7620 -12700)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 8 7620 -15240)
    )
    (image Capacitor_THT:C_Disc_D5.0mm_W2.5mm_P2.50mm
      (pin Rect[A]Pad_1600.000000x1600.000000_um 1 0 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 2 2500 0)
    )
    (image Resistor_THT:R_Axial_DIN0207_L6.3mm_D2.5mm_P7.62mm_Horizontal
      (pin Rect[A]Pad_1600.000000x1600.000000_um 1 0 0)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 2 7620 0)
    )
    (image "amstrad-adapter:DIN-8_Video"
      (pin Rect[A]Pad_1600.000000x1600.000000_um 1 0 5500)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 2 4500 -3000)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 3 0 -3000)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 4 5500 1500)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 5 3500 5000)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 6 -3500 5000)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 7 -5500 1500)
      (pin Oval[A]Pad_1600.000000x1600.000000_um 8 -4500 -3000)
      (pin Oval[A]Pad_3000.000000x3000.000000_um SH1 -7500 -5500)
      (pin Oval[A]Pad_3000.000000x3000.000000_um SH2 7500 -5500)
    )
    (image Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical
      (pin Rect[A]Pad_1700.000000x1700.000000_um 1 0 0)
      (pin Oval[A]Pad_1700.000000x1700.000000_um 2 2540 0)
    )
    (padstack Oval[A]Pad_1600.000000x1600.000000_um
      (shape (path F.Cu 1600  0 0  0 0))
      (shape (path B.Cu 1600  0 0  0 0))
      (attach off)
    )
    (padstack Oval[A]Pad_1700.000000x1700.000000_um
      (shape (path F.Cu 1700  0 0  0 0))
      (shape (path B.Cu 1700  0 0  0 0))
      (attach off)
    )
    (padstack Oval[A]Pad_3000.000000x3000.000000_um
      (shape (path F.Cu 3000  0 0  0 0))
      (shape (path B.Cu 3000  0 0  0 0))
      (attach off)
    )
    (padstack Rect[A]Pad_1600.000000x1600.000000_um
      (shape (rect F.Cu -800 -800 800 800))
      (shape (rect B.Cu -800 -800 800 800))
      (attach off)
    )
    (padstack Rect[A]Pad_1700.000000x1700.000000_um
      (shape (rect F.Cu -850 -850 850 850))
      (shape (rect B.Cu -850 -850 850 850))
      (attach off)
    )
    (padstack "Via[0-1]_600:300_um"
      (shape (circle F.Cu 600))
      (shape (circle B.Cu 600))
      (attach off)
    )
  )
  (network
    (net GND
      (pins J1-1 U1-7 U1-13 U2-4 U2-5 U2-7 U2-13 U2-12 U2-10 U2-9 C1-2 C2-2 J2-3 J2-7
        J2-SH1 J2-SH2 J3-2)
    )
    (net +5V
      (pins U1-14 U2-14 C1-1 C2-1 R1-1 J3-1)
    )
    (net RED
      (pins J1-3 U1-1)
    )
    (net RED_INV
      (pins U1-2 J2-8)
    )
    (net GREEN
      (pins J1-4 U1-3)
    )
    (net GREEN_INV
      (pins U1-4 J2-5)
    )
    (net BLUE
      (pins J1-5 U1-5)
    )
    (net BLUE_INV
      (pins U1-6 J2-6)
    )
    (net INTENSITY
      (pins J1-6 U1-9)
    )
    (net INTENSITY_INV
      (pins U1-8 J2-2)
    )
    (net HSYNC
      (pins J1-8 U2-1)
    )
    (net VSYNC
      (pins J1-9 U2-2)
    )
    (net CSYNC
      (pins U1-11 U2-3)
    )
    (net CSYNC_INV
      (pins U1-10 J2-1)
    )
    (net BLACK
      (pins R1-2 J2-4)
    )
    (class kicad_default +5V BLACK BLUE BLUE_INV CSYNC CSYNC_INV GND GREEN
      GREEN_INV HSYNC INTENSITY INTENSITY_INV RED RED_INV VSYNC
      (circuit
        (use_via "Via[0-1]_600:300_um")
      )
      (rule
        (width 400)
        (clearance 200)
      )
    )
  )
  (wiring
  )
)
